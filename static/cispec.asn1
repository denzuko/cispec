-- SPDX-License-Identifier: BSD-2-Clause
--
-- CISpec { iso org(3) dod(6) internet(1) private(4) enterprise(1)
--          daPlanetSecurity(42387) cispec(2) asn1Module(0) }
--
-- ASN.1 module defining the org.cispec Change Item attribution label set.
-- Canonical governance: https://cispec.org/
-- Validation toolkit:   https://cimatrix.org/
-- IANA PEN:             42387
-- D&B DUNS:             039-271-257
-- Spec version:         1.0
--
-- OID tree root for this module:
--   iso.org.dod.internet.private.enterprise.42387.2
--   (42387.1 is Da Planet Security's internal infrastructure arc —
--    LDAP, docs, SNMP, ASN.1 — out of scope for this specification)
--
-- Usage:
--   Compile with asn1c, OSS Nokalva, or any ASN.1/BER/DER toolchain.
--   The CISpecLabelSet SEQUENCE encodes a complete label set for one CI.
--   Individual OPTIONAL fields correspond to org.cispec.* term pages.

CISpec DEFINITIONS AUTOMATIC TAGS EXTENSIBILITY IMPLIED ::= BEGIN

IMPORTS
    -- OBJECT IDENTIFIER base from RFC 1065 / ITU-T X.208
    ;

--
-- OID assignments for this module
--

id-cispec           OBJECT IDENTIFIER ::=
    { iso org(3) dod(6) internet(1) private(4) enterprise(1) 42387 2 }

id-cispec-identity  OBJECT IDENTIFIER ::= { id-cispec 1 }
id-cispec-registry  OBJECT IDENTIFIER ::= { id-cispec 2 }
id-cispec-financial OBJECT IDENTIFIER ::= { id-cispec 3 }
id-cispec-lifecycle OBJECT IDENTIFIER ::= { id-cispec 4 }
id-cispec-custody   OBJECT IDENTIFIER ::= { id-cispec 5 }
id-cispec-types     OBJECT IDENTIFIER ::= { id-cispec 6 }
id-cispec-software  OBJECT IDENTIFIER ::= { id-cispec-types 1 }

--
-- Primitive types
--

-- Lower-case alphanumeric slug with hyphens; no leading or trailing hyphen.
-- Corresponds to the slug value format used by organization, orgunit, role.
Slug ::= UTF8String (SIZE (1..253))

-- Identity-contact value: bare email, GPG-key-ID@domain, or role:identity.
Identity ::= UTF8String (SIZE (1..512))

-- Semver 2.0 version string.
Version ::= UTF8String (SIZE (1..128))

-- OID in dotted-decimal notation (client's own arc — not DPS's 42387).
OIDString ::= UTF8String (SIZE (1..512))

-- D&B DUNS in iso.org.duns.<9-digit> OID notation.
DUNSString ::= UTF8String (SIZE (17..17))
    -- Fixed: "iso.org.duns." (13 chars) + 9 digits = 22 chars
    -- relaxed to SIZE(17..32) if org uses shorter internal DUNS notations

-- Cryptographic digest: algorithm:hexdigest, colon-separated.
DigestString ::= UTF8String (SIZE (8..256))

-- Bare reference pointer: case ID, URI, or hash pointing at an external record.
ReferencePointer ::= UTF8String (SIZE (1..1024))

--
-- Core label set — required fields for Declared conformance
--

CISpecCoreLabels ::= SEQUENCE {
    -- Required for Declared conformance
    -- docOid: 1.3.6.1.4.1.42387.2.1
    organization    [0] Slug,

    -- Required for Declared conformance
    -- docOid: 1.3.6.1.4.1.42387.2.1.1
    orgunit         [1] Slug,

    -- Required for Declared conformance
    -- X.500/X.520 organizationalUnitName lineage (RFC 4514)
    -- docOid: 1.3.6.1.4.1.42387.2.1.2
    owner           [2] Identity,

    -- Required for Declared conformance
    -- docOid: 1.3.6.1.4.1.42387.2.4
    version         [3] Version
}

--
-- Extended label set — full set including optional and CI-type-specific terms
--

CISpecLabelSet ::= SEQUENCE {
    -- Required core (Declared conformance)
    core            [0] CISpecCoreLabels,

    -- Registry terms
    -- Relational pointer to client's own OID arc (not DPS's 42387)
    -- docOid: 1.3.6.1.4.1.42387.2.2
    oid             [1] OIDString OPTIONAL,

    -- D&B DUNS, externally verifiable against D&B registry
    -- docOid: 1.3.6.1.4.1.42387.2.2.1
    duns            [2] DUNSString OPTIONAL,

    -- Financial terms
    -- docOid: 1.3.6.1.4.1.42387.2.3
    customer        [3] UTF8String OPTIONAL,

    -- docOid: 1.3.6.1.4.1.42387.2.3.1
    costcenter      [4] UTF8String OPTIONAL,

    -- Lifecycle terms
    -- Spec version labels were authored against
    -- docOid: 1.3.6.1.4.1.42387.2.4.1
    specversion     [5] Version OPTIONAL,

    -- Deployment/operational environment; purdue-level:<n> for ICS
    -- docOid: 1.3.6.1.4.1.42387.2.4.2
    environment     [6] UTF8String OPTIONAL,

    -- Custody terms (evidence CI type)
    -- Bare pointer to the chronological custody record
    -- docOid: 1.3.6.1.4.1.42387.2.5
    custodyChain    [7] ReferencePointer OPTIONAL,

    -- Cryptographic digest; REQUIRED for evidence CIs
    -- docOid: 1.3.6.1.4.1.42387.2.5.1
    checksum        [8] DigestString OPTIONAL,

    -- Software CI type terms
    -- docOid: 1.3.6.1.4.1.42387.2.6.1.1
    application     [9] UTF8String OPTIONAL,

    -- docOid: 1.3.6.1.4.1.42387.2.6.1.2
    role            [10] Slug OPTIONAL,

    -- Extension point: implementors MAY add terms under their own arc.
    -- Terms MUST resolve at a public TLS-verified domain per
    -- https://cispec.org/#minting-new-terms
    extensions      [11] SEQUENCE OF CISpecExtension OPTIONAL
}

--
-- Extension term — open namespace for implementor-minted terms
--

CISpecExtension ::= SEQUENCE {
    -- Fully-qualified term name, e.g. "org.cispec.shift-supervisor"
    termName        UTF8String,
    -- Bare string value
    termValue       UTF8String
}

--
-- Conformance levels (informational — not encoded in the label set itself)
--

CISpecConformanceLevel ::= ENUMERATED {
    -- All required core keys present and well-formed; self-asserted
    declared    (0),
    -- Mechanically verified by cimatrix; terms resolve at public TLS domain
    verified    (1),
    -- SLSA provenance attestation exists and has been verified
    attested    (2)
}

END
